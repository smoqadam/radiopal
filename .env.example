# scheduler image tag to run (defaults to latest)
IMAGE_TAG=latest

# shared music library (other apps use it too)
MUSIC_DIR=./music
# radio's own content: station_ids, short_stories, generated, poetry, ...
MEDIA_DIR=./media

ICECAST_SOURCE_USER=source
ICECAST_SOURCE_PASSWORD=hackme
ICECAST_ADMIN_PASSWORD=admin
ICECAST_RELAY_PASSWORD=hackme

DEEPSEEK_API_KEY=
NEWSAPI_KEY=
